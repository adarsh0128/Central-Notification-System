# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/notification_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App Settings
ENVIRONMENT=dev
LOG_LEVEL=info

# Mock Provider Simulator Settings
# Latency range in milliseconds (200-500ms default)
PROVIDER_MIN_LATENCY_MS=200
PROVIDER_MAX_LATENCY_MS=500

# Failure rates (0.0 to 1.0)
EMAIL_FAILURE_RATE=0.1
SMS_FAILURE_RATE=0.1
PUSH_FAILURE_RATE=0.1

# Non-Functional Requirements Configurations
# Rate Limit: notifications per hour per user
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# Idempotency key TTL in seconds (24 hours)
IDEMPOTENCY_TTL_SECONDS=86400
